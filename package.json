{
  "name": "@hexafield/matrix-link-language",
  "version": "0.1.0",
  "description": "Matrix Link Language for AD4M",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build": "deno run --allow-all esbuild.ts",
    "build:node": "node --import tsx esbuild.node.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules --import tsx --test tests/*.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.16.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0"
  }
}